### Control Layer Public API

```typescript
// src/control/index.ts — single entry point for all control layer checks

export interface ControlLayer {
  // Approvals
  checkApproval(action: string, context: Record<string, any>): Promise<ApprovalCheck>;
  requestApproval(flowId: string, entityType: string, entityId: string, data: any): Promise<ApprovalRequest>;
  approveRequest(requestId: string, reason?: string): Promise<void>;
  rejectRequest(requestId: string, reason: string): Promise<void>;
  getPendingApprovals(userId: string): Promise<ApprovalRequest[]>;

  // SLAs
  startSLATimer(entityType: string, entityId: string, slaId: string): Promise<SLATimer>;
  stopSLATimer(entityType: string, entityId: string): Promise<void>;
  checkSLABreaches(): Promise<SLABreach[]>;  // called by cron job

  // Stage rules
  checkStageEntry(dealId: string, stageId: string): Promise<StageCheck>;
  checkStageExit(dealId: string, stageId: string): Promise<StageCheck>;
  getStageRequirements(stageId: string): Promise<StageRequirements>;

  // Exceptions
  requestException(type: string, entityType: string, entityId: string, reason: string): Promise<ExceptionRequest>;
  approveException(exceptionId: string): Promise<void>;

  // Handoff
  validateHandoff(entityType: string, entityId: string, notes: string): Promise<HandoffValidation>;
  recordOwnershipChange(entityType: string, entityId: string, fromUser: string, toUser: string, handoffNoteId: string): Promise<void>;
}

interface ApprovalCheck {
  required: boolean;
  flowId?: string;
  flowName?: string;
  reason?: string;
}

interface StageCheck {
  allowed: boolean;
  missingRequirements: StageRequirement[];
}

interface StageRequirement {
  type: 'field_required' | 'document_required' | 'approval_required' | 'task_completed' | 'min_value';
  description: string;
  description_ar: string;
  met: boolean;
}

interface HandoffValidation {
  complete: boolean;
  score: number;  // 0-100
  missingItems: { item: string; reason: string }[];
}
